# App
PORT=3000
NODE_ENV=development

# Database provider (transição SQLite → Supabase)
# sqlite = banco local (padrão atual). supabase = após migração (ver docs/PROMPT-MIGRACAO-SUPABASE.md).
DB_PROVIDER=sqlite

# SQLite (usado quando DB_PROVIDER=sqlite; padrão: ./data/taskmanager.db)
SQLITE_DB_PATH=./data/taskmanager.db

# Supabase (obrigatório quando DB_PROVIDER=supabase; backend only — NUNCA exponha service role no frontend)
# Obtenha em: projeto Supabase → Settings → API. Valide com: npm run validate:supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Connection string PostgreSQL (Supabase Dashboard → Settings → Database → Connection string → Session mode)
# Formato: postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Security - CHANGE IN STAGING/PRODUCTION
JWT_SECRET=change-me-with-32-plus-random-chars
SUPER_ADMIN_KEY=change-me-super-admin-key

# System admin (created on first startup)
SYSTEM_ADMIN_EMAIL=admin@sistema.com
SYSTEM_ADMIN_PASSWORD=change-me-min-6
SYSTEM_ADMIN_NOME=Admin Sistema

# CORS / Host hardening
# Comma-separated origins in production
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex for host validation in production
ALLOWED_HOST_PATTERN=
# Domínio base da aplicação (ex.: fluxiva.com.br).
# Usado para: CORS dinâmico por subdomínio + geração do link de acesso por empresa.
# Deixe vazio em desenvolvimento local.
APP_DOMAIN=

# Rate limit / performance tuning (production/staging)
# API geral: use valor mais alto para evitar 429 indevido em leitura normal.
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300

# Login/reset: manter mais conservador por segurança.
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_RESET_WINDOW_MS=900000
RATE_LIMIT_RESET_MAX=10

# Chat:
# - leitura (GET /api/chat/*): limite dedicado para não disputar com API global
# - envio (POST /api/chat/threads/:threadId/messages): limite por usuário
# - cooldown por thread: anti-spam (1 msg/s por thread por usuário)
RATE_LIMIT_CHAT_READ_WINDOW_MS=60000
RATE_LIMIT_CHAT_READ_MAX=300
RATE_LIMIT_CHAT_SEND_WINDOW_MS=60000
RATE_LIMIT_CHAT_SEND_MAX=120
CHAT_THREAD_MIN_INTERVAL_MS=1000
CHAT_THREAD_RATE_CACHE_MAX=50000

# Feriados — job de sincronização automática (BrasilAPI)
# true ou 1 = roda sync diário ~03:00 (ano atual + próximo) para todos os tenants
# Omitir ou false = job não inicia
# HOLIDAY_SYNC_ENABLED=true

# Email (Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=Task Manager <noreply@seu-dominio.com>
