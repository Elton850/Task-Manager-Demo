# Dependencies
node_modules/
frontend/node_modules/

# Build
dist/
frontend/dist/

# Environment (nunca commitar segredos)
.env
.env.local
.env.*.local
!.env.example
!.env.development.example
!.env.staging.example
!.env.production.example

# Frontend env (Vite) — não versionar os preenchidos; só os .example
frontend/.env
frontend/.env.local
frontend/.env.*
!frontend/.env.production.example
!frontend/.env.staging.example

# Banco de dados e uploads (dados locais)
data/*.db
data/*.db-shm
data/*.db-wal
data/uploads/

# IDE / Editor
.cursor/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs e cache
*.log
npm-debug.log*
.cache/

# Arquivos legados / temporarios
*.tmp
code task-manager-sheets*
order table task-manager-sheets*
performance.html
performance-page.js
performance.css
.env.development
.env.staging
.env.production

