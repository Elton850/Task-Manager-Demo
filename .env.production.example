# =============================================================================
# PRODUÇÃO — copie para .env.production e preencha com projeto Supabase de PRODUÇÃO.
# Uso: npm run env:prod (copia para .env) antes de build/deploy de produção.
# =============================================================================
# Nunca use este arquivo com dados reais versionado. Mantenha .env.production no .gitignore.
# =============================================================================

NODE_ENV=production
PORT=3000

# Database — Supabase de produção
DB_PROVIDER=supabase
SQLITE_DB_PATH=./data/taskmanager.db

# Supabase — PROJETO DE PRODUÇÃO
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
# Connection string: Session mode (Dashboard → Settings → Database). Host deve ser *.pooler.supabase.com
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Security — obrigatório: chaves fortes e únicas
JWT_SECRET=change-me-production-min-32-random-chars
SUPER_ADMIN_KEY=change-me-production-super-admin-key

# System admin (produção)
SYSTEM_ADMIN_EMAIL=admin@seudominio.com
SYSTEM_ADMIN_PASSWORD=change-me-production-min-6
SYSTEM_ADMIN_NOME=Admin Sistema

# CORS / Host — apenas origens e hosts do site em produção
# ALLOWED_ORIGINS: lista de origens fixas permitidas (além dos subdomínios do APP_DOMAIN)
ALLOWED_ORIGINS=https://fluxiva.com.br
# Regex que valida o header Host para proteção contra Host Header Injection
# Aceita: fluxiva.com.br e qualquer-subdominio.fluxiva.com.br
ALLOWED_HOST_PATTERN=^([a-z0-9-]+\.)?fluxiva\.com\.br$
# Domínio base: habilita CORS dinâmico para *.fluxiva.com.br e gera links de acesso corretos
APP_DOMAIN=fluxiva.com.br

# Rate limit / Chat tuning
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_RESET_WINDOW_MS=900000
RATE_LIMIT_RESET_MAX=10
RATE_LIMIT_CHAT_READ_WINDOW_MS=60000
RATE_LIMIT_CHAT_READ_MAX=300
RATE_LIMIT_CHAT_SEND_WINDOW_MS=60000
RATE_LIMIT_CHAT_SEND_MAX=120
CHAT_THREAD_MIN_INTERVAL_MS=1000
CHAT_THREAD_RATE_CACHE_MAX=50000

# Supabase Storage — buckets para anexos e logos (criados automaticamente pelo backend)
# O bucket de evidências é privado; o de logos também é servido pelo backend.
SUPABASE_STORAGE_BUCKET_EVIDENCES=task-evidences
SUPABASE_STORAGE_BUCKET_LOGOS=tenant-logos

# Email — OBRIGATÓRIO para envio de códigos de acesso/redefinição de senha
# 1. Crie conta em https://resend.com e obtenha a API Key
# 2. Adicione e verifique o domínio no Resend (DNS SPF/DKIM no Hostgator ou onde o domínio estiver)
#    → Passo a passo detalhado: PASSO-A-PASSO-EMAIL-HOSTGATOR-RESEND.md
# 3. Preencha as variáveis abaixo com o domínio verificado (nunca use onboarding@resend.dev em produção)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Formato obrigatório: "Nome Exibido <email@dominio-verificado.com>"
EMAIL_FROM=Task Manager <noreply@seudominio.com>
