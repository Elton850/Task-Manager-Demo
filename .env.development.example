# =============================================================================
# DESENVOLVIMENTO LOCAL — copie para .env.development e preencha se necessário.
# Uso: npm run env:dev (copia para .env) e rode o backend.
# =============================================================================
# Base local: use sqlite para não depender de nuvem e não sujar base remota.
# Se quiser testar com Supabase em dev, crie um projeto separado e use DB_PROVIDER=supabase.
# =============================================================================

NODE_ENV=development
PORT=3000

# Database — sqlite = local, rápido, sem sujar base de staging/prod
DB_PROVIDER=sqlite
SQLITE_DB_PATH=./data/taskmanager.db

# Supabase (só se DB_PROVIDER=supabase; use projeto de DEV separado)
# SUPABASE_URL=https://your-dev-project.supabase.co
# SUPABASE_ANON_KEY=your-dev-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Security (valores fracos ok em dev local)
JWT_SECRET=dev-local-jwt-secret-min-32-characters
SUPER_ADMIN_KEY=dev-local-super-admin-key

# System admin (criado no primeiro start)
SYSTEM_ADMIN_EMAIL=admin@dev.local
SYSTEM_ADMIN_PASSWORD=change-me-dev
SYSTEM_ADMIN_NOME=Admin Dev

# CORS — apenas localhost
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOST_PATTERN=

# Rate limit / Chat tuning (opcional em dev)
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_RESET_WINDOW_MS=900000
RATE_LIMIT_RESET_MAX=10
RATE_LIMIT_CHAT_READ_WINDOW_MS=60000
RATE_LIMIT_CHAT_READ_MAX=300
RATE_LIMIT_CHAT_SEND_WINDOW_MS=60000
RATE_LIMIT_CHAT_SEND_MAX=120
CHAT_THREAD_MIN_INTERVAL_MS=1000
CHAT_THREAD_RATE_CACHE_MAX=50000

# Email (opcional)
# RESEND_API_KEY=
# EMAIL_FROM=Task Manager Dev <noreply@example.com>
