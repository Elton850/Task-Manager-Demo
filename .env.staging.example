# =============================================================================
# STAGING / TESTES — copie para .env.staging e preencha com projeto Supabase de STAGING.
# Uso: npm run env:staging (copia para .env) e faça deploy ou rode o backend apontando ao site de teste.
# =============================================================================
# Base separada da produção: testes seguros, demos, links para novos updates.
# Use um projeto Supabase DEDICADO para staging (não use o mesmo da produção).
# =============================================================================

NODE_ENV=staging
PORT=3001

# Database — sempre Supabase em staging (base de testes na nuvem)
DB_PROVIDER=supabase
SQLITE_DB_PATH=./data/taskmanager.db

# Supabase — PROJETO DE STAGING (não use o de produção)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
# Connection string: copie a string COMPLETA do Dashboard (Settings → Database → Connection string → Session mode).
# Substitua [YOUR-PASSWORD] pela senha do banco. O host deve ser real (ex.: aws-0-sa-east-1.pooler.supabase.com), NÃO use "aws-0-region".
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REAL-REGION].pooler.supabase.com:5432/postgres
# Pool PostgreSQL (opcional): PG_POOL_MAX=10 PG_IDLE_TIMEOUT_MS=30000 PG_CONNECT_TIMEOUT_MS=10000

# Security — use chaves fortes (ambiente acessível por URL)
JWT_SECRET=change-me-staging-min-32-random-chars
SUPER_ADMIN_KEY=change-me-staging-super-admin-key

# System admin (staging)
SYSTEM_ADMIN_EMAIL=admin@staging.seudominio.com
SYSTEM_ADMIN_PASSWORD=change-me-staging
SYSTEM_ADMIN_NOME=Admin Staging

# CORS / Host — URL(s) do site de TESTE
# staging.fluxiva.com.br é o domínio raiz de staging; *.staging.fluxiva.com.br são as empresas
ALLOWED_ORIGINS=https://staging.fluxiva.com.br
# Aceita: staging.fluxiva.com.br e qualquer-empresa.staging.fluxiva.com.br
ALLOWED_HOST_PATTERN=^([a-z0-9-]+\.)?staging\.fluxiva\.com\.br$
# Domínio base de staging: habilita CORS dinâmico e gera links de acesso corretos para staging
APP_DOMAIN=staging.fluxiva.com.br

# Email (opcional)
# RESEND_API_KEY=
# EMAIL_FROM=Task Manager Staging <noreply@seudominio.com>
