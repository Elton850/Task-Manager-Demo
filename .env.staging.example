# =============================================================================
# STAGING / TESTES — copie para .env.staging e preencha com projeto Supabase de STAGING.
# Uso: npm run env:staging (copia para .env) e faça deploy ou rode o backend apontando ao site de teste.
# =============================================================================
# Base separada da produção: testes seguros, demos, links para novos updates.
# Use um projeto Supabase DEDICADO para staging (não use o mesmo da produção).
# =============================================================================

NODE_ENV=staging
PORT=3001

# Database — sempre Supabase em staging (base de testes na nuvem)
DB_PROVIDER=supabase
SQLITE_DB_PATH=./data/taskmanager.db

# Supabase — PROJETO DE STAGING (não use o de produção)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
# Connection string: copie a string COMPLETA do Dashboard (Settings → Database → Connection string → Session mode).
# Substitua [YOUR-PASSWORD] pela senha do banco. O host deve ser real (ex.: aws-0-sa-east-1.pooler.supabase.com), NÃO use "aws-0-region".
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REAL-REGION].pooler.supabase.com:5432/postgres
# Pool PostgreSQL (opcional): PG_POOL_MAX=10 PG_IDLE_TIMEOUT_MS=30000 PG_CONNECT_TIMEOUT_MS=10000

# Security — use chaves fortes (ambiente acessível por URL)
JWT_SECRET=change-me-staging-min-32-random-chars
SUPER_ADMIN_KEY=change-me-staging-super-admin-key

# System admin (staging)
SYSTEM_ADMIN_EMAIL=admin@staging.seudominio.com
SYSTEM_ADMIN_PASSWORD=change-me-staging
SYSTEM_ADMIN_NOME=Admin Staging

# CORS / Host — Staging usa esquema PATH-BASED (um único host, empresas por path)
# URL de acesso: staging.fluxiva.com.br/empresa1/login  (não mais empresa.staging.fluxiva.com.br)
ALLOWED_ORIGINS=https://staging.fluxiva.com.br
# ALLOWED_HOST_PATTERN não é usado em staging (a validação usa APP_DOMAIN diretamente).
# Deixe comentado ou remova desta variável no .env.staging real na VPS.
# ALLOWED_HOST_PATTERN=
# Domínio de staging: usado para validar Host, gerar CORS e construir links path-based
APP_DOMAIN=staging.fluxiva.com.br

# Rate limit / Chat tuning
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_RESET_WINDOW_MS=900000
RATE_LIMIT_RESET_MAX=10
RATE_LIMIT_CHAT_READ_WINDOW_MS=60000
RATE_LIMIT_CHAT_READ_MAX=300
RATE_LIMIT_CHAT_SEND_WINDOW_MS=60000
RATE_LIMIT_CHAT_SEND_MAX=120
CHAT_THREAD_MIN_INTERVAL_MS=1000
CHAT_THREAD_RATE_CACHE_MAX=50000

# Supabase Storage — buckets para anexos e logos (criados automaticamente pelo backend)
# O bucket de evidências é privado; o de logos também é servido pelo backend.
SUPABASE_STORAGE_BUCKET_EVIDENCES=task-evidences
SUPABASE_STORAGE_BUCKET_LOGOS=tenant-logos

# Email — recomendado em staging para testar o fluxo completo de envio de código
# O domínio deve estar verificado no Resend (mesmo domínio da produção ou subdomínio, ex.: staging.seudominio.com)
# Se não configurado, o envio falhará com erro explícito (onboarding@resend.dev não é permitido em staging)
# Passo a passo de configuração do domínio: PASSO-A-PASSO-EMAIL-HOSTGATOR-RESEND.md
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Formato obrigatório: "Nome Exibido <email@dominio-verificado.com>"
EMAIL_FROM=Task Manager Staging <noreply@seudominio.com>
