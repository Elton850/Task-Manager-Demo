# =============================================================================
# Variáveis de ambiente do FRONTEND para build de STAGING (Vite).
# Copie para frontend/.env.staging e preencha antes do build de staging.
# Uso: cd frontend && npx vite build --mode staging
# (Vite lê frontend/.env.staging automaticamente com --mode staging)
# =============================================================================
# ATENÇÃO: variáveis VITE_* são embutidas no build (código público).
# Nunca coloque chaves secretas aqui.
# =============================================================================

# Domínio base de staging exibido na tela de empresas (esquema PATH-BASED).
# Ex.: staging.fluxiva.com.br → link = https://staging.fluxiva.com.br/empresa
# (O frontend não usa esta variável para detecção de modo; usa o hostname em runtime.)
VITE_APP_DOMAIN=staging.fluxiva.com.br
