# =============================================================================
# Variáveis de ambiente do FRONTEND para build de PRODUÇÃO (Vite).
# Copie para frontend/.env.production e preencha antes do build de produção.
# Uso: cd frontend && npm run build   (Vite lê frontend/.env.production automaticamente)
# =============================================================================
# ATENÇÃO: variáveis VITE_* são embutidas no build (código público).
# Nunca coloque chaves secretas aqui.
# =============================================================================

# Domínio base exibido na tela de empresas.
# Ex.: fluxiva.com.br → link = https://empresa.fluxiva.com.br
VITE_APP_DOMAIN=fluxiva.com.br
